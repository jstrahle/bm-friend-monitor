# ---- Pushover credentials (required) -------------------------------------
# Create an application at https://pushover.net/apps/build to get the token.
# Your user key is shown on your Pushover dashboard.
PUSHOVER_TOKEN=your_pushover_app_token
PUSHOVER_USER=your_pushover_user_key

# Optional Pushover tweaks:
# PUSHOVER_PRIORITY=0          # -2..2 (0 = normal, 1 = high, 2 = emergency)
# PUSHOVER_DEVICE=phone        # restrict to one device (default: all devices)
# PUSHOVER_SOUND=pushover      # a sound name from your Pushover account

# ---- Who/what to watch (set at least one) --------------------------------
# All lists are comma-separated; each entry may carry an optional "=Label".
WATCH_DMR_IDS=2161234=John, 2625001=Anna
# WATCH_CALLSIGNS=VK3ABC=Dave, W1AW
# WATCH_TALKGROUPS=91=Worldwide, 244=Finland
# WATCH_REPEATERS=204204=Home repeater

# Note: DMR IDs, talkgroups, and repeaters are filtered server-side (efficient).
# Callsigns can't be; if you set WATCH_CALLSIGNS the app receives the whole
# network feed and matches locally.

# ---- Behaviour (optional) ------------------------------------------------
# Seconds of silence (per dedup bucket) before notifying again.
MIN_SILENCE=300
# Ignore transmissions shorter than this many seconds (0 = report all).
MIN_DURATION=0
# Which event to act on. Session-Stop fires once per completed transmission.
NOTIFY_ON=Session-Stop
# Logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ---- Dedup granularity (optional) ----------------------------------------
# How wide one anti-flood bucket is, per match category. Scopes:
#   station | station_tg | talkgroup | repeater | station_repeater
# Defaults give you one alert per person-per-talkgroup, but only one alert for
# a busy talkgroup or repeater as a whole.
# DEDUP_PERSON=station_tg      # DMR ID / callsign matches
# DEDUP_TALKGROUP=talkgroup    # talkgroup matches (use station_tg for per-op)
# DEDUP_REPEATER=repeater      # repeater matches (use station_repeater for per-op)

# ---- Quiet hours (optional) ----------------------------------------------
# During this LOCAL-time window, downgrade ("low") or suppress ("mute") alerts.
# Leave QUIET_HOURS empty to always notify normally.
# QUIET_HOURS=23:00-07:00
# QUIET_TZ=Europe/Helsinki     # IANA tz name; default UTC
# QUIET_HOURS_MODE=low         # "low" (quiet priority) or "mute" (no alert)
# QUIET_PRIORITY=-1            # Pushover priority used in "low" mode

# ---- Health (optional; defaults are fine) --------------------------------
# HEALTH_FILE=/tmp/bm_health   # refreshed while connected; watched by HEALTHCHECK
# HEALTH_MAX_AGE=90            # seconds before the container is marked unhealthy
